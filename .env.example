# Required
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude authentication:
#   Option 1: API key
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   Option 2: run `claude login` first, then leave ANTHROPIC_API_KEY unset

# Optional (defaults shown)
CLAUDE_MODEL=claude-opus-4-6
MAX_REVIEW_TURNS=30
POLL_INTERVAL_MS=60000
REVIEW_TIMEOUT_MS=600000
WORK_DIR=/tmp/ironsha
TRANSCRIPT_DIR=/tmp/ironsha/transcripts
MAX_WRITE_TURNS=50
WRITE_TIMEOUT_MS=900000
MAX_REVIEW_CYCLES=5
CI_POLL_TIMEOUT_MS=600000
MERGE_CONFLICT_TIMEOUT_MS=300000
LOG_LEVEL=info
