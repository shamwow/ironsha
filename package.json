{
  "name": "ironsha",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "ironsha": "dist/main.js"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/*.test.js dist/**/*.test.js",
    "test:integration": "npm run build && node --test --test-timeout=900000 dist/integration/*.integration.test.js",
    "test:integration:mock_llm": "npm run build && node --test --test-timeout=900000 dist/integration/*.integration.test.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
